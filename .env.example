# OKX API credentials
OKX__API_KEY=your_api_key
OKX__SECRET_KEY=your_secret_key
OKX__PASSPHRASE=your_passphrase
# Set to true for demo/paper trading (recommended for testing)
OKX__IS_DEMO=false

# Risk parameters (optional overrides)
RISK__MAX_POSITION_PCT=0.1
RISK__MAX_DAILY_LOSS_PCT=0.02
RISK__MAX_DRAWDOWN_PCT=0.05

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# SQLite database path
DB_PATH=trade.db

# Strategy config file
STRATEGY_CONFIG=config/strategies.yaml